{
  "expo": {
    "name": "Anonymous Secrets",
    "slug": "anonymous-secrets-app",
    "version": "20.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "anonymous-secrets-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.kirasiris.anonymoussecretsapp"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "c05e300e-e7a9-40d5-b42f-b79d05cd9050"
      }
    },
    "owner": "kirasiris"
  }
}
